{
	"name": "pg-tables-to-zod",
	"version": "1.0.20",
	"description": "A command-line utility and module to turn postgres tables into Zod schemas",
	"homepage": "https://github.com/springtree/pg-tables-to-zod#readme",
	"bugs": {
		"url": "https://github.com/springtree/pg-tables-to-zod/issues"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/springtree/pg-tables-to-zod.git"
	},
	"bin": {
		"pgtables2zod": "dist/cli.js"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			}
		},
		"./package.json": "./package.json"
	},
	"scripts": {
		"build": "bunup",
		"dev": "bunup --watch",
		"postinstall": "bun simple-git-hooks",
		"fmt": "oxfmt --check",
		"fmt:fix": "oxfmt",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"release": "bumpp --commit --push --tag",
		"test": "bun test",
		"test:coverage": "bun test --coverage",
		"test:watch": "bun test --watch",
		"type-check": "tsc --noEmit"
	},
	"dependencies": {
		"commander": "^14.0.3",
		"lodash-es": "^4.18.1",
		"pg-structure": "^7.15.3",
		"prompts": "^2.4.2",
		"ts-morph": "^28.0.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@types/bun": "^1.3.14",
		"@types/lodash-es": "^4.17.12",
		"@types/prompts": "^2.4.9",
		"@typescript/native-preview": "^7.0.0-dev.20260527.2",
		"bumpp": "^11.1.0",
		"bunup": "^0.16.31",
		"oxfmt": "^0.52.0",
		"oxlint": "^1.67.0",
		"oxlint-tsgolint": "^0.23.0",
		"simple-git-hooks": "^2.13.1",
		"typescript": "^6.0.3"
	},
	"peerDependencies": {
		"typescript": ">=4.5.0"
	},
	"peerDependenciesMeta": {
		"typescript": {
			"optional": true
		}
	},
	"simple-git-hooks": {
		"pre-commit": "bun run lint && bun run type-check"
	}
}
